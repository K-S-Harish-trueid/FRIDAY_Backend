# Copy this file to .env and fill in values before enabling the relevant service.
# .env is gitignored — never commit real keys.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── LLM API keys (uncomment when wiring up the service) ──────────────────────
GROQ_API_KEY=gsk_...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# ── External API base URLs ────────────────────────────────────────────────────
# POKEAPI_BASE_URL=https://pokeapi.co/api/v2
# OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
# OPENWEATHER_API_KEY=
